# Onda — Configuración de despliegue
# Copia este archivo a .env y ajusta los valores:
#   cp .env.example .env

# ── ROCm (solo AMD APU) ────────────────────────
# ⚠️ DEBUG ONLY — No soportado oficialmente por AMD
# ⚠️ Ver docker-compose.rocm.yml para advertencias completas
# ⚠️ Puede causar GPU Hang, pantalla congelada, pérdida de datos
#
# Necesario para AMD APUs Radeon 780M/760M/740M (gfx1103)
# Valores: 11.0.0 (gfx1100), 11.0.2 (gfx1102, recomendado)
# HSA_OVERRIDE_GFX_VERSION=11.0.2

# ── Modelos ──────────────────────────────────
# Ruta donde están (o se descargarán) los modelos de separación
# Puede ser absoluta (/datos/onda/models) o relativa (./models)
MODEL_DIR=./models

# ── Permisos ─────────────────────────────────
# UID/GID del usuario host (para que los archivos de salida tengan tus permisos)
# Déjalo en 1000 si es una instalación single-user estándar
HOST_UID=1000
HOST_GID=1000

# ── Puertos ──────────────────────────────────
# Puerto donde se sirve la interfaz web
ONDA_PORT=3000
