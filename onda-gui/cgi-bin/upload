#!/bin/bash
# CGI: Upload file → /input (raw POST body + X-Filename header)
echo "Content-Type: application/json"
echo ""

FILENAME=$(echo "$HTTP_X_FILENAME" | tr -d "\r\n" | sed "s/[^a-zA-Z0-9._-]//g")

if [ -z "$FILENAME" ]; then
    echo "{\"success\":false,\"error\":\"No X-Filename header\"}"
    exit 0
fi

if [ -z "$CONTENT_LENGTH" ] || [ "$CONTENT_LENGTH" -eq 0 ]; then
    echo "{\"success\":false,\"error\":\"Empty file\"}"
    exit 0
fi

# Write raw stdin to /input
cat > "/input/$FILENAME"

if [ -f "/input/$FILENAME" ]; then
    SIZE=$(stat -c%s "/input/$FILENAME" 2>/dev/null || echo 0)
    echo "{\"success\":true,\"message\":\"$FILENAME ($SIZE bytes)\"}"
else
    echo "{\"success\":false,\"error\":\"Write failed\"}"
fi
