#!/bin/bash
# CGI: List input audio files → JSON
echo "Content-Type: application/json"
echo ""

INPUT_DIR="/input"

echo -n "{\"files\":["
first=true

for f in "$INPUT_DIR"/*; do
    [ -f "$f" ] || continue
    name=$(basename "$f")
    ext="${name##*.}"
    case "$ext" in
        wav|WAV|mp3|MP3|flac|FLAC|ogg|OGG|aac|AAC|m4a|M4A|aiff|AIFF) ;;
        *) continue ;;
    esac
    $first || echo -n ","
    echo -n "{\"name\":\"$name\",\"path\":\"$f\"}"
    first=false
done

echo "]}"
